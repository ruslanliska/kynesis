# Environment: dev | staging | production
ENV=dev
DEBUG=true

# API Key (shared secret for frontend/backend to access this server)
API_KEY=your-api-key-here

# OpenAI
OPENAI__API_KEY=sk-...

# DeepSeek (reasoning + structuring models for assessment pipeline)
DEEPSEEK__API_KEY=sk-...

# Assessment pipeline (two-stage reasoning)
# Defaults work out-of-the-box; override only to change models/policy.
ASSESSMENT__REASONING_MODEL=deepseek-reasoner
ASSESSMENT__STRUCTURING_MODEL=deepseek-chat
ASSESSMENT__STRUCTURING_TEMPERATURE=0.1
ASSESSMENT__REASONING_RETRIES=1
ASSESSMENT__STRUCTURING_RETRIES=3
ASSESSMENT__REQUEST_TIMEOUT_SECONDS=180
ASSESSMENT__STRUCTURING_RESERVED_SECONDS=15
ASSESSMENT__FAILURE_POLICY=fallback

# Pinecone
PINECONE__API_KEY=pcsk-...
PINECONE__INDEX_NAME=kynesis
PINECONE__CLOUD=aws
PINECONE__REGION=us-east-1

# Logfire (observability)
LOGFIRE__TOKEN=
LOGFIRE__SEND_TO_LOGFIRE=false

# LangSmith (LLM observability)
LANGSMITH__API_KEY=
LANGSMITH__PROJECT=kynesis
LANGSMITH__TRACING=false
LANGSMITH__ENDPOINT=https://api.smith.langchain.com

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","https://your-lovable-app.lovable.app"]

# Retained for future use
SUPABASE_JWT_SECRET=
DATABASE_URL=
