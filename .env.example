# Environment: dev | staging | production
# Set ENV to load .env.{ENV} overrides on top of .env
ENV=dev
DEBUG=true

# API Key (shared secret for frontend/backend to access this server)
API_KEY=your-api-key-here

# AI Provider (Pydantic AI model string)
AI_MODEL=openai:gpt-4o
OPENAI_API_KEY=sk-...

# Pinecone (vector DB for knowledge base)
PINECONE_API_KEY=pcsk-...
PINECONE_INDEX_NAME=kynesis
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Logfire (observability)
LOGFIRE_TOKEN=
LOGFIRE_SEND_TO_LOGFIRE=false

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","https://your-lovable-app.lovable.app"]

# Retained for future use (not used by current endpoints)
SUPABASE_JWT_SECRET=
DATABASE_URL=
