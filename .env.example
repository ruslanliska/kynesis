# Environment: dev | staging | production
ENV=dev
DEBUG=true

# API Key (shared secret for frontend/backend to access this server)
API_KEY=your-api-key-here

# OpenAI
OPENAI__API_KEY=sk-...

# Pinecone
PINECONE__API_KEY=pcsk-...
PINECONE__INDEX_NAME=kynesis
PINECONE__CLOUD=aws
PINECONE__REGION=us-east-1

# Logfire (observability)
LOGFIRE__TOKEN=
LOGFIRE__SEND_TO_LOGFIRE=false

# LangSmith (LLM observability)
LANGSMITH__API_KEY=
LANGSMITH__PROJECT=kynesis
LANGSMITH__TRACING=false
LANGSMITH__ENDPOINT=https://api.smith.langchain.com

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","https://your-lovable-app.lovable.app"]

# Retained for future use
SUPABASE_JWT_SECRET=
DATABASE_URL=
